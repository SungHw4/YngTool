{
  "name": "yngtool",
  "version": "1.0.1",
  "description": "개인 개발자 업무 대시보드",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:react": "react-scripts start",
    "dev:electron": "cross-env ELECTRON_IS_DEV=1 electron .",
    "build": "react-scripts build && electron-builder",
    "build:react": "react-scripts build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dayjs": "^1.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "homepage": ".",
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  },
  "build": {
    "appId": "com.yngtool.app",
    "productName": "YngTool",
    "files": [
      "build/**/*",
      "src/main/**/*"
    ],
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  }
}
